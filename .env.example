# ============================================================
# MindCare Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# === REQUIRED ===
# Mistral API key — get yours at https://console.mistral.ai/
# Without this key:
#   - ECO mode works (ML classifier + CSV advice)
#   - AGENT and HYBRID modes are disabled
#   - RAG vectorstore cannot be built (no embeddings)

MISTRAL_API_KEY=your_mistral_api_key_here

# === OPTIONAL — LangSmith Tracing ===
# Enables full observability of agent trajectories.
# Sign up at https://smith.langchain.com/ (free tier available).
# When disabled, the agent works normally without tracing.
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=mindcare-agent